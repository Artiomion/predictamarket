# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/predictamarket

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=<run: openssl rand -hex 32>
JWT_ALGORITHM=HS256
JWT_EXPIRATION=15
JWT_REFRESH_EXPIRATION=43200

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_ANNUAL=price_...

# External APIs
FRED_API_KEY=

# Observability
SENTRY_DSN=

# Internal service-to-service — generate with: openssl rand -hex 32
INTERNAL_API_KEY=<run: openssl rand -hex 32>

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Airflow — generate Fernet key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=change-me-generate-with-fernet
AIRFLOW_ADMIN_PASSWORD=change-me
AIRFLOW_WEBSERVER_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# App
APP_ENV=development
DEBUG=true
